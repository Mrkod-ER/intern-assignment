// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  passwordHash String
  createdAt    DateTime      @default(now())
  lists        List[]
  savedSearches SavedSearch[]
  notes        Note[]
  thesis       Thesis?
  customCompanies CustomCompany[]
}

model List {
  id        String        @id @default(uuid())
  name      String
  createdAt DateTime      @default(now())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  companies ListCompany[]
}

model ListCompany {
  id        String @id @default(uuid())
  listId    String
  companyId String
  list      List   @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, companyId])
}

model SavedSearch {
  id          String   @id @default(uuid())
  query       String   @default("")
  filtersJson String   @default("{}")
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(uuid())
  companyId String
  content   String
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model Thesis {
  id          String   @id @default(uuid())
  dataJson    String   @default("{}")
  updatedAt   DateTime @updatedAt
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CustomCompany {
  id            String   @id @default(uuid())
  name          String
  website       String
  description   String   @default("")
  industry      String   @default("Unknown")
  stage         String   @default("Unknown")
  hq            String   @default("Unknown")
  founded       String   @default("Unknown")
  tagsJson      String   @default("[]")
  enrichmentJson String  @default("{}")
  status        String   @default("new")
  createdAt     DateTime @default(now())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
